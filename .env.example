# MongoDB Atlas connection string
# Lấy tại: https://cloud.mongodb.com -> Connect -> Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/vinaphone-ai

# OpenAI API key
# Lấy tại: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gemini API key
# Lấy tại: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API key
# Lấy tại: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth secret - tạo bằng lệnh: openssl rand -base64 32
NEXTAUTH_SECRET=

# URL của website khi deploy (production)
NEXTAUTH_URL=http://localhost:3000
